# PostgreSQL Database Credentials (for psycopg2 / docker connections)
DB_HOST=postgres_db
DB_PORT=5432
DB_NAME=classicmodels
DB_USER=myuser
DB_PASSWORD=mypassword

# Combined Connection URL (Alternative option)
DATABASE_URL=postgresql://myuser:mypassword@postgres_db:5432/classicmodels

# Gemini API Key Rotation Configuration (Supports comma-separated keys)
# The system will cycle through keys dynamically to bypass 5 RPM Free Tier rate limits!
GEMINI_API_KEYS=first_gemini_key_here,second_gemini_key_here,third_gemini_key_here
